rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teachers - only the teacher can read their own doc
    match /teachers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Created manually via Firebase Console
    }

    // Classes - anyone can read (to verify class code), only teachers can write
    // Exception: authenticated users can increment studentCount on join
    match /classes/{code} {
      allow read: if true;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
      allow update: if request.auth != null
        && (exists(/databases/$(database)/documents/teachers/$(request.auth.uid))
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount'])
                && request.resource.data.studentCount == resource.data.studentCount + 1));
      allow delete: if false;
    }

    // Students - authenticated users can create, owner can update
    // Re-login after logout creates a new anonymous UID, so allow updates
    // that only change firebaseUid and lastActiveAt (for UID reassignment)
    match /students/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.firebaseUid == request.auth.uid
            || exists(/databases/$(database)/documents/teachers/$(request.auth.uid))
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['firebaseUid', 'lastActiveAt']));
    }

    // Progress - owner writes, teachers can read
    match /progress/{studentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Assignments - teachers write, anyone authenticated can read
    match /assignments/{id} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // Results - students create, teachers read
    match /results/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
